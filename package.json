{
  "name": "today",
  "version": "1.0.0",
  "description": "Obsidian Today plugin",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build:css": "tailwindcss -i src/styles.src.css -o styles.css --minify",
    "watch:css": "tailwindcss -i src/styles.src.css -o styles.css --watch",
    "build": "npm run build:css && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/node": "^16.11.6",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.17.3",
    "esbuild-svelte": "^0.9.5",
    "obsidian": "latest",
    "svelte": "^5.55.5",
    "svelte-preprocess": "^6.0.3",
    "tslib": "2.4.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "mobile-drag-drop": "^3.0.0-rc.0"
  }
}
